<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StudyHelper.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:chat="clr-namespace:StudyHelper.Chat"
    xmlns:vision="clr-namespace:StudyHelper.Vision"
    Title="StudyHelper">

    <TabBar>
        <ShellContent
            Title="Chat"
            ContentTemplate="{DataTemplate chat:ChatPage}"
            Route="ChatPage" />

        <ShellContent
            Title="Vision"
            ContentTemplate="{DataTemplate vision:VisionPage}"
            Route="VisionPage" />
    </TabBar>

</Shell>
