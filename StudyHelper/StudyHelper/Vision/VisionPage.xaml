<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyHelper.Vision.VisionPage">
    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Button
                Text="Choose Image" 
                Clicked="OnChooseClicked"
                HorizontalOptions="Fill" />

            <!-- captured photo preview -->
            <Image
                x:Name="CapturedImage"
                HeightRequest="200"
                Aspect="AspectFit"
                IsVisible="True" />

            <Editor
                x:Name="UserPrompt"
                Placeholder="Enter your question" />
            
            <Button
                x:Name="Send"
                Text="Send"
                Clicked="OnSendClicked" />
            
            <ActivityIndicator 
                x:Name="Indicator" />
            
            <Label x:Name="Response" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>