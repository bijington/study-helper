<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StudyHelper.Chat.ChatPage">

    <ScrollView>
        <Grid
            ColumnDefinitions="*,Auto"
            RowDefinitions="*,Auto">
            <Editor
                x:Name="UserPrompt"
                Placeholder="Enter your question"
                Grid.Row="1" />

            <Button
                Text="Send"
                Clicked="OnSendClicked"
                Grid.Column="1"
                Grid.Row="1" />

            <Editor
                x:Name="Response"
                IsReadOnly="True"
                Grid.ColumnSpan="2" />
        </Grid>
    </ScrollView>

</ContentPage>
